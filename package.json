{
  "name": "fund-baby",
  "version": "1.0",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0 && prettier --check .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config vitest.config.mjs --configLoader runner --pool threads",
    "test:unit:watch": "vitest --config vitest.config.mjs --configLoader runner --pool threads",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci:test": "pnpm typecheck && pnpm lint && pnpm test:unit && pnpm test:e2e"
  },
  "dependencies": {
    "@dicebear/collection": "^9.3.1",
    "@dicebear/core": "^9.3.1",
    "dayjs": "^1.11.19",
    "echarts": "^6.0.0",
    "framer-motion": "^12.29.2",
    "next": "^16.1.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.37.0",
    "eslint-config-next": "^16.1.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.10.0",
    "eslint-plugin-testing-library": "^7.16.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vitest": "^0.5.4",
    "jsdom": "^29.0.0",
    "msw": "^2.12.13",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
